   "id": "44841c11",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 1000x500 with 1 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    }
   ],
   "source": [
    "tabla_dinamica = ds_limpio.pivot_table(\n",
    "    values = \"show_id\",\n",
    "    index = \"country\",\n",
    "    columns = \"type\",\n",
    "    aggfunc= \"count\",\n",
    ").fillna(0)\n",
    "\n",
    "top_10_paises = tabla_dinamica.sum(axis=1).nlargest(10).index\n",
    "tabla_top10 = tabla_dinamica.loc[top_10_paises]\n",
    "\n",
    "ax = tabla_top10.plot(kind=\"bar\", figsize=(10, 5), width=0.8)\n",
    "\n",
    "plt.title(\n",
    "    \"Comparativa de Películas y Series por País (Top 10)\",\n",
    "    fontsize=12,\n",
    "    fontweight=\"bold\",\n",
    ")\n",
    "plt.xlabel(\"País\")\n",
    "plt.ylabel(\"Cantidad de Títulos\")\n",
    "plt.xticks(rotation=45)\n",
    "plt.legend(title=\"Tipo\")\n",
    "plt.tight_layout()\n",
    "\n",
    "plt.show()"
   ]
